  "components": {
    "schemas": {
      "CreatePersonalTokenRequest": {
        "type": "object"
      },
      "CreatePersonalTokenResponse": {
        "type": "object",
        "description": "PAT 作成時のレスポンス（平文トークンはこの応答でのみ返却）",
        "required": [
          "token",
          "id",
          "name",
          "token_last_four",
          "expires_at",
          "last_used_at",
          "revoked",
          "user_id",
          "scopes"
        ],
        "properties": {
          "expires_at": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "last_used_at": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "name": {
            "type": "string"
          },
          "revoked": {
            "type": "boolean"
          },
          "scopes": {
            "$ref": "#/components/schemas/ScopeList"
          },
          "token": {
            "type": "string"
          },
          "token_last_four": {
            "type": "string"
          },
          "user_id": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": [
          "email",
          "password"
        ],
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string",
            "format": "password"
          }
        }
      },
      "PersonalTokenResponse": {
        "type": "object",
        "description": "PAT のメタデータ（平文トークン・ハッシュは含まない）",
        "required": [
          "id",
          "name",
          "token_last_four",
          "expires_at",
          "last_used_at",
          "revoked",
          "user_id",
          "scopes"
        ],
        "properties": {
          "expires_at": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "last_used_at": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "name": {
            "type": "string"
          },
          "revoked": {
            "type": "boolean"
          },
          "scopes": {
            "$ref": "#/components/schemas/ScopeList"
          },
