    "@tanstack/vue-table": "8.21.3",
    "arkenv": "0.11.0",
    "arktype": "2.2.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-vue-next": "1.0.0",
