{
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "types": ["vite/client"],
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "paths": {
      "#/*": ["./server/*"],
      "@/*": ["./src/*"],
      "@/sentry.browser.config": ["./sentry.browser.config.ts"]
    }
  },
  "include": ["src/**/*", "server/**/*", "stories/**/*", "sentry.browser.config.ts"],
  "references": [{ "path": "./tsconfig.node.json" }],
  "exclude": ["dist"]
}
