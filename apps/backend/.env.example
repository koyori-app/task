# 未指定時は info,sqlx=warn（2秒/30秒ポーリングの空 SELECT をログに出さない）
# RUST_LOG=info,sqlx=warn
# Drive ストレージ: local | s3
STORAGE_BACKEND=local
LOCAL_UPLOAD_DIR=./uploads
UPLOAD_MAX_SIZE_MB=100
DRIVE_SYSTEM_MAX_QUOTA_MB=51200
DRIVE_DEFAULT_QUOTA_MB=10240
# S3 利用時（STORAGE_BACKEND=s3）
# S3_ENDPOINT=http://127.0.0.1:9000
# S3_BUCKET=drive
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=minioadmin
# S3_SECRET_ACCESS_KEY=minioadmin
# S3_PUBLIC_BASE_URL=http://127.0.0.1:9000/drive
# S3_FORCE_PATH_STYLE=true
database_url=postgresql://username:password@host:port/db_name
redis_url=redis://127.0.0.1:6379
sentry_dsn=
smtp_host=smtp.example.com
smtp_port=587
smtp_username=your_smtp_username
smtp_password=your_smtp_password
smtp_from=no-reply@example.com
# 必須。認証メールのリンク先（本番では実際のフロント URL を指定）
email_verification_app_url=http://localhost:3000
# 認証メール Apalis ワーカー並列度（本番では 2 以上を検討）
# verification_email_worker_concurrency=2
# ジョブ管理 UI: http://localhost:3400/ （/jobs は / へリダイレクト。本番はネットワーク制限を推奨）
personal_token_secret=your_personal_token_secret
# OAuth（有効化するプロバイダのみ設定。OAUTH_ENCRYPTION_KEY は起動時必須・32文字以上）
# APP_BASE_URL=http://localhost:3400
# OAUTH_ENCRYPTION_KEY=your-32-char-or-longer-encryption-key-here
# OAUTH_GITHUB_CLIENT_ID=
# OAUTH_GITHUB_CLIENT_SECRET=