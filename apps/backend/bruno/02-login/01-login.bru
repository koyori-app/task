meta {
  name: 4. ログイン
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/v1/auth/login
  body: json
  auth: none
}

headers {
  content-type: application/json
}

body:json {
  {
    "email": "{{email}}",
    "password": "{{password}}"
  }
}

vars:pre-request {
  baseUrl: "{{baseUrl}}"
  email: "{{email}}"
}

tests {
  test("should return 204", function() {
    expect(res.status).to.equal(204);
  });
}
