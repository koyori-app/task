meta {
  name: 20 公開リンク・ファイル一覧
  type: http
  seq: 20
}

get {
  url: {{base_url}}/v1/drive/share/{{share_token}}/files
  body: none
  auth: none
}

headers {
  accept: application/json
}

tests {
  test("status 200", function() {
    expect(res.status).to.equal(200);
  });
  test("returns array", function() {
    expect(res.body).to.be.an("array");
  });
}
