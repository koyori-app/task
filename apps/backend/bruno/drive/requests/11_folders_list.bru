meta {
  name: 11 フォルダ一覧
  type: http
  seq: 11
}

get {
  url: {{base_url}}/v1/tenants/{{tenant_id}}/drive/folders
  body: none
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

headers {
  accept: application/json
}

tests {
  test("status 200", function() {
    expect(res.status).to.equal(200);
  });
  test("returns array", function() {
    expect(res.body).to.be.an("array");
  });
}
