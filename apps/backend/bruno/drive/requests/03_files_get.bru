meta {
  name: 03 ファイルメタデータ取得
  type: http
  seq: 3
}

get {
  url: {{base_url}}/v1/tenants/{{tenant_id}}/drive/files/{{file_id}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

headers {
  accept: application/json
}

tests {
  test("status 200", function() {
    expect(res.status).to.equal(200);
  });
  test("returns file id", function() {
    expect(res.body.id).to.equal(bru.getVar("file_id"));
  });
}
