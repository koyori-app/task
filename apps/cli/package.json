{
  "name": "@koyori/task-cli",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "task": "./bin/task.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "openapi:generate": "openapi-typescript ../frontend/openapi.json -o ./src/api/openapi.d.ts",
    "test": "pnpm run build && vitest run",
    "typecheck:test": "tsc -p tsconfig.test.json"
  },
  "dependencies": {
    "commander": "15.0.0",
    "js-yaml": "4.3.0",
    "openapi-fetch": "0.17.0"
  },
  "devDependencies": {
    "@types/js-yaml": "4.0.9",
    "@types/node": "24.13.3",
    "openapi-typescript": "7.13.0",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
